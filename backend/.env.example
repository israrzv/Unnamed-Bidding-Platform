# Copy to `.env` and fill in. These are SECRET — never commit the real file.

PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# Supabase Postgres. Use the session pooler (port 5432) for a long-running server.
# Get it from Supabase → Connect → ORMs, and URL-encode special chars in the password.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Verifies the JWTs the frontend sends.
# Supabase dashboard → Settings → API → JWT Settings → "JWT Secret".
SUPABASE_JWT_SECRET=
